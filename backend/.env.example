# Server
PORT=5000
NODE_ENV=development

# ─── Database (MySQL) ──────────────────────────────────────────────────────────
# Changed from PostgreSQL → MySQL
#   DB_USER : your MySQL username (default root, use a dedicated app user in prod)
#   DB_PORT : MySQL default is 3306  (was 5432 for PostgreSQL)
DB_USER=root
DB_HOST=localhost
DB_NAME=esports_platform
DB_PASSWORD=CHANGE_ME_DB_PASSWORD
DB_PORT=3306

# JWT — use a long random string (e.g. openssl rand -hex 64)
JWT_SECRET=CHANGE_ME_JWT_SECRET_MIN_32_CHARS
JWT_EXPIRES_IN=7d

# CORS — comma-separated list of allowed origins
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# ─── Admin ────────────────────────────────────────────────────────────────────
ADMIN_EMAILS=admin@yourdomain.com

# ─── Email / SMTP ─────────────────────────────────────────────────────────────
# Gmail example:
#   SMTP_HOST=smtp.gmail.com
#   SMTP_PORT=587
#   SMTP_USER=you@gmail.com
#   SMTP_PASS=your-app-password   ← generate at myaccount.google.com/apppasswords
#
# Brevo (free 300/day): smtp-relay.brevo.com  port 587
# SendGrid:             smtp.sendgrid.net      port 587  (user=apikey, pass=your-api-key)
# Mailgun:              smtp.mailgun.org       port 587
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=CHANGE_ME_EMAIL@gmail.com
SMTP_PASS=CHANGE_ME_APP_PASSWORD

# Third-party API keys
HENRIKDEV_KEY=CHANGE_ME
TRACKER_GG_KEY=CHANGE_ME
