# Server
PORT=5000
NODE_ENV=development

# Database
DB_USER=postgres
DB_HOST=localhost
DB_NAME=esports_platform
DB_PASSWORD=your_password_here
DB_PORT=5432

# JWT
JWT_SECRET=replace_with_a_long_random_secret_string_at_least_64_chars
JWT_EXPIRES_IN=7d

# CORS — comma-separated list of allowed origins
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# RAWG Video Games Database API (free — get yours at https://rawg.io/apidocs)
RAWG_API_KEY=your_rawg_api_key_here

# Optional: protect the /api/games/sync endpoint with this secret header value
# Set to a random string; call with: X-Sync-Secret: <value>
# Leave blank to allow unauthenticated sync (dev only)
RAWG_SYNC_SECRET=
